{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "webclient",
  "projectType": "application",
  "sourceRoot": "apps/webclient/src",
  "tags": ["scope:webclient", "type:app"],
  "targets": {
    "build": {
      "executor": "@nx/vite:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/webclient",
        "configFile": "apps/webclient/vite.config.ts"
      }
    },
    "serve": {
      "executor": "@nx/vite:dev-server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "webclient:build",
        "hmr": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["apps/webclient/**/*.ts", "apps/webclient/**/*.tsx"]
      }
    },
    "test": {
      "executor": "@nx/vite:test",
      "outputs": ["{workspaceRoot}/coverage/apps/webclient"],
      "options": {
        "configFile": "apps/webclient/vitest.config.ts"
      }
    },
    "docker-build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -f apps/webclient/Dockerfile -t ssa-webclient ."
      }
    }
  }
}
